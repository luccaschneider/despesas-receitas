# Copiar para `.env` (não commite `.env`): `docker compose` carrega esse arquivo por padrão.
#
# --- Banco e aplicação (obrigatórios para o perfil default / PostgreSQL) ---
# Em Homolog e Produção, a infraestrutura deve injetar os mesmos nomes de variável.
# URL JDBC do Postgres (no Compose, o host do serviço é `db`):
DB_URL=jdbc:postgresql://db:5432/despesas_receitas
DB_USER=postgres
DB_PASSWORD=defina_uma_senha_forte
# Porta HTTP do Spring Boot (fallback no código: 8080 se não definido)
SERVER_PORT=8080
# Perfil Spring: `homolog` ou `prod` (ajustes em application-homolog.properties / application-prod.properties)
SPRING_PROFILES_ACTIVE=homolog

# --- PostgreSQL (Compose) — alinhar POSTGRES_* com DB_USER / DB_PASSWORD ---
POSTGRES_DB=despesas_receitas
# Porta publicada no host (opcional; padrão 5432)
POSTGRES_PORT=5432

# --- E-mail (opcional): para enviar e-mails pela aplicação, defina SMTP e APP_EMAIL_ENABLED=true
APP_EMAIL_ENABLED=false
APP_EMAIL_DESTINATARIO=
APP_EMAIL_REMETENTE=
APP_EMAIL_SMTP_HOST=
APP_EMAIL_SMTP_PORT=587
APP_EMAIL_SMTP_USERNAME=
APP_EMAIL_SMTP_PASSWORD=
APP_EMAIL_SMTP_AUTH=true
APP_EMAIL_SMTP_STARTTLS=true
APP_EMAIL_SMTP_DEBUG=false
